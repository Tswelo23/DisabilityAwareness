@{
    ViewData["Title"] = "Inclusion Guide - Creating Accessible & Inclusive Communities";
}

<!-- Hero Section -->
<section class="hero-section" style="background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-10 mx-auto text-center hero-content">
                <h1>
                    Building <span class="highlight">Inclusive</span><br>
                    Communities & Workplaces
                </h1>
                <p class="lead">
                    Practical strategies, tools, and resources to create accessible environments,
                    promote diversity, and ensure equal participation for everyone.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Inclusion Principles -->
<section class="py-5">
    <div class="container py-4">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center mb-5">
                <h2 class="mb-4">Core Principles of Inclusion</h2>
                <p class="lead">
                    Inclusion means creating environments where everyone can participate fully,
                    regardless of ability, background, or circumstance.
                </p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="principle-card">
                    <div class="principle-icon">
                        <i class="fas fa-universal-access"></i>
                    </div>
                    <h4>Accessibility</h4>
                    <p>Removing barriers so everyone can access spaces, information, and opportunities.</p>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="principle-card">
                    <div class="principle-icon">
                        <i class="fas fa-balance-scale"></i>
                    </div>
                    <h4>Equity</h4>
                    <p>Providing what each person needs to have equal opportunities and outcomes.</p>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="principle-card">
                    <div class="principle-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h4>Participation</h4>
                    <p>Ensuring everyone can engage fully in all aspects of community life.</p>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="principle-card">
                    <div class="principle-icon">
                        <i class="fas fa-hands-helping"></i>
                    </div>
                    <h4>Respect</h4>
                    <p>Valuing diversity and treating everyone with dignity and consideration.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Workplace Inclusion -->
<section id="workplace-inclusion" class="py-5 bg-light">
    <div class="container py-4">
        <h2 class="text-center mb-5">Workplace Inclusion Strategies</h2>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="inclusion-card">
                    <h4><i class="fas fa-building text-primary me-2"></i> Hiring & Recruitment</h4>
                    <p>Create inclusive hiring processes that welcome candidates with disabilities.</p>
                    <ul class="inclusion-list">
                        <li>Accessible job descriptions and application processes</li>
                        <li>Disability-inclusive recruitment partnerships</li>
                        <li>Reasonable accommodation during interviews</li>
                        <li>Bias-free selection criteria</li>
                    </ul>
                    <div class="resource-links">
                        <a href="https://www.askjan.org" target="_blank" class="resource-link">
                            <i class="fas fa-external-link-alt me-1"></i>
                            Job Accommodation Network
                        </a>
                        <a href="https://www.dol.gov/odep" target="_blank" class="resource-link">
                            <i class="fas fa-external-link-alt me-1"></i>
                            Office of Disability Employment Policy
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="inclusion-card">
                    <h4><i class="fas fa-users-cog text-primary me-2"></i> Workplace Accommodations</h4>
                    <p>Implement reasonable accommodations to support employees with disabilities.</p>
                    <ul class="inclusion-list">
                        <li>Flexible work arrangements</li>
                        <li>Assistive technology and equipment</li>
                        <li>Accessible workspaces and facilities</li>
                        <li>Modified work schedules</li>
                    </ul>
                    <div class="resource-links">
                        <a href="https://www.tshirologo.co.za" target="_blank" class="resource-link">
                            <i class="fas fa-external-link-alt me-1"></i>
                            Tshirologo Workplace Solutions
                        </a>
                        <a href="https://www.disabilitysa.org/workplace" target="_blank" class="resource-link">
                            <i class="fas fa-external-link-alt me-1"></i>
                            Disability SA Workplace Guide
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="inclusion-card">
                    <h4><i class="fas fa-chart-line text-primary me-2"></i> Career Development</h4>
                    <p>Ensure equal opportunities for advancement and professional growth.</p>
                    <ul class="inclusion-list">
                        <li>Mentorship programs for employees with disabilities</li>
                        <li>Accessible training and development programs</li>
                        <li>Inclusive leadership development</li>
                        <li>Career path planning</li>
                    </ul>
                    <div class="resource-links">
                        <a href="https://www.dpmsa.org.za" target="_blank" class="resource-link">
                            <i class="fas fa-external-link-alt me-1"></i>
                            Disability Professionals Management SA
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="inclusion-card">
                    <h4><i class="fas fa-handshake text-primary me-2"></i> Inclusive Culture</h4>
                    <p>Foster a workplace culture that values diversity and inclusion.</p>
                    <ul class="inclusion-list">
                        <li>Disability awareness training</li>
                        <li>Employee resource groups</li>
                        <li>Inclusive communication practices</li>
                        <li>Celebration of diversity</li>
                    </ul>
                    <div class="resource-links">
                        <a href="https://www.diversitysa.org" target="_blank" class="resource-link">
                            <i class="fas fa-external-link-alt me-1"></i>
                            Diversity South Africa
                        </a>
                        <a href="https://www.inclusionhub.com" target="_blank" class="resource-link">
                            <i class="fas fa-external-link-alt me-1"></i>
                            Inclusion Hub
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Physical Accessibility Guide -->
<section id="physical-accessibility" class="py-5">
    <div class="container py-4">
        <h2 class="text-center mb-5">Physical Accessibility Guide</h2>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="accessibility-guide">
                    <h4><i class="fas fa-wheelchair text-success me-2"></i> Mobility Access</h4>
                    <div class="checklist">
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Wide doorways (minimum 32 inches)</span>
                        </div>
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Ramp access with proper slope (1:12 ratio)</span>
                        </div>
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Accessible parking close to entrances</span>
                        </div>
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Clear pathways without obstacles</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="accessibility-guide">
                    <h4><i class="fas fa-eye text-success me-2"></i> Visual Accessibility</h4>
                    <div class="checklist">
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>High contrast signage and markings</span>
                        </div>
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Braille signage for rooms and facilities</span>
                        </div>
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Adequate lighting in all areas</span>
                        </div>
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Tactile warning surfaces</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="accessibility-guide">
                    <h4><i class="fas fa-deaf text-success me-2"></i> Hearing Accessibility</h4>
                    <div class="checklist">
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Visual fire alarms and notifications</span>
                        </div>
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Hearing loop systems in meeting rooms</span>
                        </div>
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Sign language interpretation services</span>
                        </div>
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Captioning for videos and presentations</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="accessibility-guide">
                    <h4><i class="fas fa-brain text-success me-2"></i> Cognitive Accessibility</h4>
                    <div class="checklist">
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Clear, simple signage and directions</span>
                        </div>
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Quiet spaces and sensory rooms</span>
                        </div>
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Consistent layout and design</span>
                        </div>
                        <div class="checklist-item">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Multiple information formats available</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Digital Accessibility -->
<section id="digital-accessibility" class="py-5 bg-light">
    <div class="container py-4">
        <h2 class="text-center mb-5">Digital Accessibility Standards</h2>

        <div class="row">
            <div class="col-lg-10 mx-auto">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h4 class="mb-4"><i class="fas fa-laptop-code text-primary me-2"></i> WCAG 2.1 Guidelines</h4>
                        <p>The Web Content Accessibility Guidelines (WCAG) provide standards for making web content accessible to people with disabilities.</p>

                        <div class="row mt-4">
                            <div class="col-md-4">
                                <div class="wcag-principle">
                                    <h5>Perceivable</h5>
                                    <p>Information must be presentable in ways users can perceive.</p>
                                    <ul>
                                        <li>Text alternatives for images</li>
                                        <li>Captions for multimedia</li>
                                        <li>Adaptable content</li>
                                        <li>Distinguishable content</li>
                                    </ul>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="wcag-principle">
                                    <h5>Operable</h5>
                                    <p>Interface components must be operable by all users.</p>
                                    <ul>
                                        <li>Keyboard accessible</li>
                                        <li>Enough time</li>
                                        <li>Seizure safe</li>
                                        <li>Navigable</li>
                                    </ul>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="wcag-principle">
                                    <h5>Understandable</h5>
                                    <p>Information and operation must be understandable.</p>
                                    <ul>
                                        <li>Readable text</li>
                                        <li>Predictable operation</li>
                                        <li>Input assistance</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="digital-card">
                            <h5><i class="fas fa-check-circle text-success me-2"></i> Website Accessibility</h5>
                            <ul>
                                <li>Proper heading structure</li>
                                <li>Descriptive link text</li>
                                <li>Sufficient color contrast</li>
                                <li>Keyboard navigation</li>
                                <li>Alternative text for images</li>
                            </ul>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="digital-card">
                            <h5><i class="fas fa-check-circle text-success me-2"></i> Document Accessibility</h5>
                            <ul>
                                <li>Properly tagged PDFs</li>
                                <li>Accessible Word documents</li>
                                <li>Structured PowerPoint slides</li>
                                <li>Readable font sizes</li>
                                <li>Logical reading order</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

