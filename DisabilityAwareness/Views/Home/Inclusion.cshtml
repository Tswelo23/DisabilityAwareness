<!-- Inclusion Assessment Tool -->
<section class="py-5 bg-light">
    <div class="container py-4">
        <h2 class="text-center mb-5">Inclusion Self-Assessment</h2>

        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card border-0 shadow-lg">
                    <div class="card-body p-5">
                        <h4 class="text-center mb-4">How Inclusive Is Your Organization?</h4>
                        <p class="text-center mb-4">Take this quick assessment to evaluate your current inclusion practices.</p>

                        <form id="inclusion-assessment">
                            <div class="mb-4">
                                <h5>1. Physical Accessibility</h5>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="physical-access" id="physical-1" value="1">
                                    <label class="form-check-label" for="physical-1">
                                        Basic accessibility (ramps, accessible bathrooms)
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="physical-access" id="physical-2" value="2">
                                    <label class="form-check-label" for="physical-2">
                                        Good accessibility with some assistive features
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="physical-access" id="physical-3" value="3">
                                    <label class="form-check-label" for="physical-3">
                                        Comprehensive accessibility for all disabilities
                                    </label>
                                </div>
                            </div>

                            <div class="mb-4">
                                <h5>2. Digital Accessibility</h5>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="digital-access" id="digital-1" value="1">
                                    <label class="form-check-label" for="digital-1">
                                        Basic website accessibility
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="digital-access" id="digital-2" value="2">
                                    <label class="form-check-label" for="digital-2">
                                        WCAG 2.0 AA compliance
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="digital-access" id="digital-3" value="3">
                                    <label class="form-check-label" for="digital-3">
                                        WCAG 2.1 AA compliance with regular testing
                                    </label>
                                </div>
                            </div>

                            <div class="mb-4">
                                <h5>3. Inclusive Hiring</h5>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="hiring" id="hiring-1" value="1">
                                    <label class="form-check-label" for="hiring-1">
                                        Equal opportunity employer
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="hiring" id="hiring-2" value="2">
                                    <label class="form-check-label" for="hiring-2">
                                        Active outreach to candidates with disabilities
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="hiring" id="hiring-3" value="3">
                                    <label class="form-check-label" for="hiring-3">
                                        Comprehensive disability inclusion program
                                    </label>
                                </div>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-chart-bar me-2"></i>
                                    Get Your Inclusion Score
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

