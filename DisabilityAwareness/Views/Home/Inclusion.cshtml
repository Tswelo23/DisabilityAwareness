<!-- Modal for Assessment Results -->
<div class="modal fade" id="assessmentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Your Inclusion Score</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <div class="mb-4">
                    <div class="inclusion-score">
                        <span id="scoreValue">0</span>
                        <small>/9</small>
                    </div>
                    <h4 id="scoreTitle" class="mt-3">Getting Started</h4>
                </div>

                <div id="scoreDescription">
                    <p>Your organization is beginning its inclusion journey. Consider these next steps:</p>
                    <ul class="text-start">
                        <li>Conduct an accessibility audit</li>
                        <li>Provide basic disability awareness training</li>
                        <li>Review hiring practices</li>
                    </ul>
                </div>

                <div class="mt-4">
                    <a href="#inclusion-training" class="btn btn-primary" data-bs-dismiss="modal">
                        Explore Training Resources
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize back-to-top button
            initBackToTop();

            // Smooth scrolling for anchor links
            $('a[href^="#"]').on('click', function(e) {
                e.preventDefault();
                var target = $(this).attr('href');
                if(target.length) {
                    $('html, body').stop().animate({
                        scrollTop: $(target).offset().top - 80
                    }, 1000);
                }
            });

            // Inclusion assessment form
            $('#inclusion-assessment').submit(function(e) {
                e.preventDefault();

                // Calculate score
                let score = 0;
                $('input[type="radio"]:checked').each(function() {
                    score += parseInt($(this).val());
                });

                // Determine level and message
                let title = '';
                let description = '';

                if (score <= 3) {
                    title = 'Getting Started';
                    description = '<p>Your organization is beginning its inclusion journey. Consider these next steps:</p><ul class="text-start"><li>Conduct an accessibility audit</li><li>Provide basic disability awareness training</li><li>Review hiring practices</li><li>Identify priority areas for improvement</li></ul>';
                } else if (score <= 6) {
                    title = 'Making Progress';
                    description = '<p>Your organization has made good progress. Continue building on your foundation:</p><ul class="text-start"><li>Implement comprehensive accessibility standards</li><li>Develop disability inclusion policies</li><li>Provide advanced training for staff</li><li>Establish employee resource groups</li></ul>';
                } else {
                    title = 'Inclusion Leader';
                    description = '<p>Your organization is a leader in disability inclusion. Continue your excellent work:</p><ul class="text-start"><li>Share best practices with other organizations</li><li>Mentor other businesses in inclusion</li><li>Participate in inclusion awards and recognition</li><li>Continue innovation in accessibility</li></ul>';
                }

                // Update modal content
                $('#scoreValue').text(score);
                $('#scoreTitle').text(title);
                $('#scoreDescription').html(description);

                // Show modal
                var assessmentModal = new bootstrap.Modal(document.getElementById('assessmentModal'));
                assessmentModal.show();
            });

            // Function to show toast notifications
            function showToast(message, type = 'info') {
                // Remove existing toast
                $('.toast-notification').remove();

                // Set colors based on type
                let bgColor = 'var(--primary)';
                if (type === 'error') bgColor = '#ef4444';
                if (type === 'success') bgColor = '#10b981';
                if (type === 'warning') bgColor = '#f59e0b';

                // Create toast
                const toast = $('<div class="toast-notification"></div>')
                    .text(message)
                    .css({
                        position: 'fixed',
                        top: '20px',
                        right: '20px',
                        background: bgColor,
                        color: 'white',
                        padding: '12px 24px',
                        borderRadius: '8px',
                        boxShadow: '0 4px 12px rgba(0,0,0,0.15)',
                        zIndex: '10000',
                        fontSize: '14px',
                        animation: 'slideInRight 0.3s ease-out'
                    })
                    .appendTo('body');

                // Remove after 3 seconds
                setTimeout(function() {
                    toast.animate({ opacity: 0, right: '-100px' }, 300, function() {
                        $(this).remove();
                    });
                }, 3000);
            }
        });

        function initBackToTop() {
            // Back to top button
            $('#back-to-top').click(function(e) {
                e.preventDefault();
                $('html, body').animate({
                    scrollTop: 0
                }, 800);
                return false;
            });

            // Show/hide back-to-top button
            $(window).scroll(function() {
                if ($(window).scrollTop() > 300) {
                    $('#back-to-top').fadeIn();
                } else {
                    $('#back-to-top').fadeOut();
                }
            });

            // Initialize button visibility
            if ($(window).scrollTop() > 300) {
                $('#back-to-top').show();
            } else {
                $('#back-to-top').hide();
            }
        }
    </script>
}