        <div class="row mt-5">
            <div class="col-lg-8 mx-auto">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h4 class="text-center mb-4">Service Request Form</h4>
                        <p class="text-center mb-4">Need help finding specific services? Let us assist you.</p>

                        <form id="service-request">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Name *</label>
                                    <input type="text" class="form-control" placeholder="Your name" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Email *</label>
                                    <input type="email" class="form-control" placeholder="Your email" required>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Phone Number</label>
                                    <input type="tel" class="form-control" placeholder="Your phone number">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Service Category *</label>
                                    <select class="form-select" required>
                                        <option value="">Select service category...</option>
                                        <option>Assistive Technology</option>
                                        <option>Personal Support</option>
                                        <option>Educational Support</option>
                                        <option>Employment Services</option>
                                        <option>Housing Support</option>
                                        <option>Health Services</option>
                                        <option>Other</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Specific Needs *</label>
                                <textarea class="form-control" rows="3" placeholder="Describe what you're looking for..." required></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Location (City/Province)</label>
                                <input type="text" class="form-control" placeholder="e.g., Johannesburg, Gauteng">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Preferred Contact Method</label>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="contactMethod" id="email" checked>
                                    <label class="form-check-label" for="email">Email</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="contactMethod" id="phone">
                                    <label class="form-check-label" for="phone">Phone</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="contactMethod" id="both">
                                    <label class="form-check-label" for="both">Both</label>
                                </div>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-paper-plane me-2"></i>
                                    Submit Service Request
                                </button>
                            </div>

                            <div class="mt-3 text-center">
                                <small class="text-muted">
                                    <i class="fas fa-shield-alt me-1"></i>
                                    Your information is secure and will only be used to connect you with appropriate service providers.
                                </small>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

