@{
    ViewData["Title"] = "Support Services - Disability Resources & Assistance";
}

<!-- Hero Section -->
<section class="hero-section" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-10 mx-auto text-center hero-content">
                <h1>
                    Support Services &<br>
                    <span class="highlight">Resources</span>
                </h1>
                <p class="lead">
                    Discover comprehensive support services, assistive technologies, and resources
                    designed to empower individuals with disabilities and promote inclusion.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Services Overview -->
<section class="py-5">
    <div class="container py-4">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center mb-5">
                <h2 class="mb-4">Comprehensive Support Services</h2>
                <p class="lead">
                    We connect individuals with disabilities to essential services, technologies,
                    and resources that enhance independence and participation.
                </p>
            </div>
        </div>

        <!-- Service Categories -->
        <div class="row g-4">
            <div class="col-md-4">
                <div class="service-card h-100">
                    <div class="service-icon bg-primary">
                        <i class="fas fa-user-cog"></i>
                    </div>
                    <h3 class="mt-4">Assistive Technology</h3>
                    <p>Tools and devices that help individuals perform tasks they might otherwise be unable to do</p>
                    <ul class="service-list">
                        <li>Screen readers & magnifiers</li>
                        <li>Speech recognition software</li>
                        <li>Alternative input devices</li>
                        <li>Environmental controls</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-4">
                <div class="service-card h-100">
                    <div class="service-icon bg-success">
                        <i class="fas fa-hands-helping"></i>
                    </div>
                    <h3 class="mt-4">Personal Support</h3>
                    <p>Services that provide direct assistance and support for daily living activities</p>
                    <ul class="service-list">
                        <li>Personal care attendants</li>
                        <li>Sign language interpreters</li>
                        <li>Job coaches</li>
                        <li>Transportation assistance</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-4">
                <div class="service-card h-100">
                    <div class="service-icon bg-warning">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                    <h3 class="mt-4">Educational Support</h3>
                    <p>Resources and accommodations for academic success at all educational levels</p>
                    <ul class="service-list">
                        <li>Academic accommodations</li>
                        <li>Tutoring services</li>
                        <li>Assistive learning technology</li>
                        <li>Transition planning</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-4">
                <div class="service-card h-100">
                    <div class="service-icon bg-info">
                        <i class="fas fa-briefcase"></i>
                    </div>
                    <h3 class="mt-4">Employment Services</h3>
                    <p>Support for finding, obtaining, and maintaining meaningful employment</p>
                    <ul class="service-list">
                        <li>Vocational rehabilitation</li>
                        <li>Job placement assistance</li>
                        <li>Workplace accommodations</li>
                        <li>Career counseling</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-4">
                <div class="service-card h-100">
                    <div class="service-icon bg-danger">
                        <i class="fas fa-home"></i>
                    </div>
                    <h3 class="mt-4">Housing Support</h3>
                    <p>Resources for accessible and independent living arrangements</p>
                    <ul class="service-list">
                        <li>Accessible housing resources</li>
                        <li>Home modification grants</li>
                        <li>Independent living centers</li>
                        <li>Supported living services</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-4">
                <div class="service-card h-100">
                    <div class="service-icon bg-purple">
                        <i class="fas fa-heartbeat"></i>
                    </div>
                    <h3 class="mt-4">Health Services</h3>
                    <p>Healthcare and wellness services tailored to disability needs</p>
                    <ul class="service-list">
                        <li>Specialized healthcare</li>
                        <li>Therapy services</li>
                        <li>Mental health support</li>
                        <li>Nutrition counseling</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Assistive Technology Showcase -->
<section class="py-5 support-section">
    <div class="container py-4">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h2 class="mb-4">Assistive Technology Solutions</h2>
                <p class="mb-4">
                    Technology can be a powerful equalizer, providing tools that enable independence
                    and participation in all aspects of life.
                </p>

                <div class="tech-category mb-4">
                    <h5><i class="fas fa-desktop text-primary me-2"></i> Computer Access</h5>
                    <ul>
                        <li><a href="https://www.freedomscientific.com/products/software/jaws/" target="_blank">JAWS Screen Reader</a></li>
                        <li><a href="https://www.nvaccess.org" target="_blank">NVDA (Free Screen Reader)</a></li>
                        <li><a href="https://www.nuance.com/dragon.html" target="_blank">Dragon Speech Recognition</a></li>
                        <li><a href="https://www.microsoft.com/en-us/accessibility" target="_blank">Microsoft Accessibility Tools</a></li>
                    </ul>
                </div>

                <div class="tech-category mb-4">
                    <h5><i class="fas fa-mobile-alt text-primary me-2"></i> Mobile Accessibility</h5>
                    <ul>
                        <li><a href="https://www.apple.com/accessibility/" target="_blank">Apple Accessibility Features</a></li>
                        <li><a href="https://www.android.com/accessibility/" target="_blank">Android Accessibility Suite</a></li>
                        <li><a href="https://www.microsoft.com/en-us/seeing-ai" target="_blank">Seeing AI by Microsoft</a></li>
                        <li><a href="https://be-my-eyes.com" target="_blank">Be My Eyes App</a></li>
                    </ul>
                </div>

                <div class="tech-category">
                    <h5><i class="fas fa-universal-access text-primary me-2"></i> Daily Living Aids</h5>
                    <ul>
                        <li><a href="https://www.assistiveware.com" target="_blank">AssistiveWare Communication Tools</a></li>
                        <li><a href="https://www.permobil.com" target="_blank">Permobil Mobility Solutions</a></li>
                        <li><a href="https://www.invacare.com" target="_blank">Invacare Medical Equipment</a></li>
                        <li><a href="https://www.enableireland.ie" target="_blank">Enable Ireland Assistive Devices</a></li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card border-0 shadow-lg">
                    <div class="card-body p-4">
                        <h4 class="text-center mb-4">Technology Assessment</h4>
                        <p class="text-center mb-4">Find the right assistive technology for your needs</p>

                        <form id="tech-assessment">
                            <div class="mb-3">
                                <label class="form-label">Primary Need Area</label>
                                <select class="form-select" id="need-area">
                                    <option selected>Select an area...</option>
                                    <option>Vision/Reading</option>
                                    <option>Hearing/Communication</option>
                                    <option>Mobility/Physical Access</option>
                                    <option>Learning/Cognitive</option>
                                    <option>Daily Living Activities</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Technology Experience Level</label>
                                <select class="form-select" id="experience-level">
                                    <option>Beginner</option>
                                    <option>Intermediate</option>
                                    <option>Advanced</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Budget Range (Rands)</label>
                                <select class="form-select" id="budget-range">
                                    <option>Under R1,000</option>
                                    <option>R1,000 - R5,000</option>
                                    <option>R5,000 - R10,000</option>
                                    <option>R10,000 - R50,000</option>
                                    <option>Over R50,000</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-search me-2"></i>
                                Find Recommended Technology
                            </button>
                        </form>

                        <div class="mt-4 text-center">
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                This tool provides general recommendations. Consult with a professional for personalized assessment.
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

